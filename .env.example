# GTITI — Environment variables
# Copy this file to .env and fill in the values you have.
# The server works without any keys — PeeringDB and RIPE are free and open.

# ── PeeringDB ──────────────────────────────────────────────────────────────
# Optional: create a free account at https://www.peeringdb.com/register
# Having an account gives you higher rate limits.
PEERINGDB_API_KEY=

# ── RIPE NCC ───────────────────────────────────────────────────────────────
# No key needed. RIPE Stat API is public.

# ── Crunchbase (phase 2) ───────────────────────────────────────────────────
# Get a key at https://www.crunchbase.com/api
CRUNCHBASE_API_KEY=

# ── LinkedIn (phase 2) ─────────────────────────────────────────────────────
# LinkedIn restricts API access. Options: RapidAPI proxies or manual enrichment.
LINKEDIN_API_KEY=

# ── Server settings ────────────────────────────────────────────────────────
# How many seconds to wait for an external API before giving up
REQUEST_TIMEOUT=10

# How many API calls to make in parallel when looking up one operator
MAX_CONCURRENT_REQUESTS=5
